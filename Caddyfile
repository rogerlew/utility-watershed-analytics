{
    email brandon.xu@wsu.edu
}

firewisewatersheds.org, unstable.wepp.cloud {
    root * /app/client/build

    @artifacts {
        host firewisewatersheds.org
        path /artifacts/v1/production/*
    }

    handle @artifacts {
        uri strip_prefix /artifacts
        reverse_proxy http://100.87.36.38:18080
    }

    handle {
        route {
            # Proxy API/admin/backend routes to Django
            @backend path /api/* /admin/* /silk/*
            reverse_proxy @backend server:8000

            # Serve frontend files
            try_files {path} /index.html
            file_server
        }
    }
    
    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    }
}
