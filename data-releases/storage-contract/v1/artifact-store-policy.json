{
  "contract_version": 1,
  "storage": {
    "id": "forest1-local-filesystem",
    "host": "forest1",
    "filesystem": "zfs",
    "root": "/wc1/utility-watershed-analytics-artifacts/v1",
    "database_backup_root": "/wc1/utility-watershed-analytics-db-backups",
    "network_service_required": false,
    "paid_provider_required": false
  },
  "ownership": {
    "operator": "roger",
    "single_operator": true,
    "directory_mode": "0700",
    "file_mode": "0600",
    "public_access_prohibited": true,
    "credentials_required": false
  },
  "namespaces": [
    {
      "environment": "test",
      "path": "/wc1/utility-watershed-analytics-artifacts/v1/test"
    },
    {
      "environment": "production",
      "path": "/wc1/utility-watershed-analytics-artifacts/v1/production"
    }
  ],
  "key_layout": {
    "algorithm": "sha256",
    "template": "objects/sha256/<first-two-hex>/<full-lowercase-sha256>",
    "regex": "^objects/sha256/[a-f0-9]{2}/[a-f0-9]{64}$",
    "mutable_alias_is_authority": false,
    "overwrite_allowed": false
  },
  "publication": {
    "write_to_unique_temporary_file": true,
    "atomic_promote_after_verification": true,
    "verify_sha256_before_copy": true,
    "verify_sha256_after_copy": true,
    "existing_key_requires_full_verification": true,
    "partial_file_cleanup_required": true
  },
  "retention": {
    "minimum_releases": 3,
    "required_release_roles": [
      "active",
      "rollback-1",
      "rollback-2"
    ],
    "retained_release_ttl": null,
    "automatic_deletion_allowed": false,
    "manual_preview_required": true
  },
  "recovery": {
    "restore_host": "forest1",
    "minimum_backed_up_releases": 3,
    "verify_after_backup": true,
    "verify_after_restore": true,
    "quarterly_restore_drill_required": true,
    "provider_dependency": false
  },
  "monitoring": {
    "minimum_free_bytes": 107374182400,
    "check_free_space_before_copy": true,
    "inventory_hash_required": true,
    "nonzero_exit_on_failure": true,
    "external_alerting_required": false
  }
}
