{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://firewisewatersheds.org/schemas/data-release/v1/batch-member-index.schema.json",
  "title": "Exact collection member index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "collection_key",
    "source_revision",
    "created_at",
    "expected_member_count",
    "members"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "collection_key": {
      "$ref": "#/$defs/key"
    },
    "source_revision": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "authentication": {
      "$ref": "#/$defs/authentication"
    },
    "expected_member_count": {
      "type": "integer",
      "minimum": 1
    },
    "members": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/member"
      }
    }
  },
  "$defs": {
    "key": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "minLength": 1,
      "maxLength": 96
    },
    "runid": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "pattern": "^[^\\u0000-\\u001F\\u007F]+$"
    },
    "authentication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "secret_ref"
      ],
      "properties": {
        "secret_ref": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]{2,127}$"
        }
      }
    },
    "artifactSet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metadata",
        "boundary",
        "subcatchments",
        "channels",
        "hillslopes",
        "soils",
        "landuse"
      ],
      "properties": {
        "metadata": {"$ref": "artifact-reference.schema.json"},
        "boundary": {"$ref": "artifact-reference.schema.json"},
        "subcatchments": {"$ref": "artifact-reference.schema.json"},
        "channels": {"$ref": "artifact-reference.schema.json"},
        "hillslopes": {"$ref": "artifact-reference.schema.json"},
        "soils": {"$ref": "artifact-reference.schema.json"},
        "landuse": {"$ref": "artifact-reference.schema.json"}
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "watersheds",
        "subcatchments",
        "channels",
        "bounds"
      ],
      "properties": {
        "watersheds": {
          "const": 1
        },
        "subcatchments": {
          "type": "integer",
          "minimum": 1
        },
        "channels": {
          "type": "integer",
          "minimum": 1
        },
        "bounds": {
          "type": "array",
          "prefixItems": [
            {"type": "number", "minimum": -180, "maximum": 180},
            {"type": "number", "minimum": -90, "maximum": 90},
            {"type": "number", "minimum": -180, "maximum": 180},
            {"type": "number", "minimum": -90, "maximum": 90}
          ],
          "minItems": 4,
          "maxItems": 4
        }
      }
    },
    "member": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "watershed_key",
        "runid",
        "display_name",
        "aliases",
        "artifacts",
        "expected"
      ],
      "properties": {
        "watershed_key": {
          "$ref": "#/$defs/key"
        },
        "runid": {
          "$ref": "#/$defs/runid"
        },
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        },
        "aliases": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/runid"
          }
        },
        "artifacts": {
          "$ref": "#/$defs/artifactSet"
        },
        "transformation_lineage": {
          "$ref": "artifact-reference.schema.json"
        },
        "rhessys_index": {
          "$ref": "artifact-reference.schema.json"
        },
        "expected": {
          "$ref": "#/$defs/expected"
        }
      }
    }
  }
}
