{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://firewisewatersheds.org/schemas/data-release/v1/plans/empty-build-plan.schema.json",
  "title": "Empty-build deployment plan",
  "allOf": [
    {"$ref": "deployment-plan.schema.json"},
    {
      "properties": {
        "plan_kind": {"const": "empty-build"},
        "base": {"$ref": "deployment-plan.schema.json#/$defs/emptyState"}
      }
    },
    {"not": {"required": ["inverse_of_plan_sha256"]}}
  ]
}
