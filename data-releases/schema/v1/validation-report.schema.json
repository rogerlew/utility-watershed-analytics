{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://firewisewatersheds.org/schemas/data-release/v1/validation-report.schema.json",
  "title": "Sanitized validation report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "report_id",
    "subject",
    "validator",
    "started_at",
    "completed_at",
    "status",
    "checks"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "report_id": {
      "$ref": "#/$defs/key"
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "enum": [
            "artifact",
            "member",
            "release",
            "transformation",
            "capability"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255
        }
      }
    },
    "validator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "git_commit",
        "image_digest"
      ],
      "properties": {
        "git_commit": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "image_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      }
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "enum": [
        "passed",
        "failed"
      ]
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "status"
        ],
        "properties": {
          "code": {
            "$ref": "#/$defs/key"
          },
          "status": {
            "enum": [
              "passed",
              "failed"
            ]
          },
          "count": {
            "type": "integer",
            "minimum": 0
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          }
        }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    }
  },
  "$defs": {
    "key": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "minLength": 1,
      "maxLength": 96
    }
  }
}
