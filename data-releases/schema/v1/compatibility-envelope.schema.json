{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://firewisewatersheds.org/schemas/data-release/v1/compatibility-envelope.schema.json",
  "title": "Data-release compatibility envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "data_contract",
    "identity_contract",
    "artifact_contract",
    "supported_migrations",
    "materializer",
    "toolchain"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "data_contract": {
      "const": 1
    },
    "identity_contract": {
      "const": 1
    },
    "artifact_contract": {
      "const": 1
    },
    "supported_migrations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimum",
        "maximum"
      ],
      "properties": {
        "minimum": {
          "type": "string",
          "pattern": "^watershed\\.[0-9]{4}_[a-z0-9_]+$"
        },
        "maximum": {
          "type": "string",
          "pattern": "^watershed\\.[0-9]{4}_[a-z0-9_]+$"
        }
      }
    },
    "materializer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "image_digest",
        "git_commit"
      ],
      "properties": {
        "image_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "git_commit": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        }
      }
    },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "postgres",
        "postgis",
        "gdal"
      ],
      "properties": {
        "postgres": {
          "type": "string",
          "pattern": "^[0-9]+(?:\\.[0-9]+){1,2}$"
        },
        "postgis": {
          "type": "string",
          "pattern": "^[0-9]+(?:\\.[0-9]+){1,2}$"
        },
        "gdal": {
          "type": "string",
          "pattern": "^[0-9]+(?:\\.[0-9]+){1,2}$"
        }
      }
    }
  }
}
