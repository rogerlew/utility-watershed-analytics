# Install as /etc/utility-watershed-analytics/runtime.env with mode 0600.
# This is a minimized production runtime contract, not a development .env.

POSTGIS_IMAGE=postgis/postgis@sha256:REPLACE_WITH_OBSERVED_PRODUCTION_DIGEST
POSTGRES_USER=REPLACE_WITH_RUNTIME_DATABASE_ROLE
POSTGRES_PW=REPLACE_WITH_RUNTIME_DATABASE_PASSWORD
POSTGRES_DB=REPLACE_WITH_DATABASE_NAME
DJANGO_SECRET_KEY=REPLACE_WITH_DJANGO_SECRET
WEPPCLOUD_JWT_TOKEN=REPLACE_WITH_CURRENT_TOKEN
WEPPCLOUD_JWT_TOKEN_2=REPLACE_WITH_CURRENT_SECONDARY_TOKEN

GUNICORN_WORKERS=8
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=180
GUNICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=2000
GUNICORN_MAX_REQUESTS_JITTER=200
