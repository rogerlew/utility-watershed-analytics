[Unit]
Description=Utility Watershed Analytics encrypted production database backup
OnFailure=uwa-db-backup-failure@%n.service
ConditionPathIsDirectory=%h/.local/lib/utility-watershed-analytics-backup/current

[Service]
Type=oneshot
WorkingDirectory=%h/.local/lib/utility-watershed-analytics-backup/current
EnvironmentFile=%h/.config/utility-watershed-analytics/backup.env
ExecStart=%h/.local/lib/utility-watershed-analytics-backup/current/scripts/with_operation_lock.sh --mode shared -- %h/.local/lib/utility-watershed-analytics-backup/current/scripts/run_scheduled_backup.sh
TimeoutStartSec=4h
UMask=0077
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7
NoNewPrivileges=true
