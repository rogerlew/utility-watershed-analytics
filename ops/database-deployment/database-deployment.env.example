# Install as /etc/utility-watershed-analytics/database-deployment.env, mode 0600.
# Replace every placeholder through the approved secret-delivery path.
POSTGRES_USER=uwa_activation_login
POSTGRES_PW=replace-through-secret-delivery
POSTGRES_DB=utility_watershed_analytics
RESTIC_REPOSITORY=sftp:forest1:/wc1/utility-watershed-analytics-db-backups/repository
RESTIC_PASSWORD_FILE=/etc/utility-watershed-analytics/restic-password
UWA_DB_DEPLOY_PHASE_ROOT=/usr/local/lib/utility-watershed-analytics/database-deployment-phases
