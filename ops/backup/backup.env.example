# Install as /etc/utility-watershed-analytics/backup.env with mode 0600.
# Replace every placeholder. Never commit the installed file or its values.

RESTIC_REPOSITORY=s3:https://OBJECT-STORE-ENDPOINT/PROJECT-BUCKET/uwa-postgres
RESTIC_PASSWORD_FILE=/etc/utility-watershed-analytics/restic-password
RESTIC_BIN=/usr/bin/restic

AWS_ACCESS_KEY_ID=REPLACE_WITH_BACKUP_WRITER_KEY_ID
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_BACKUP_WRITER_SECRET

BACKUP_FAILURE_WEBHOOK_URL_FILE=/etc/utility-watershed-analytics/backup-failure-webhook
BACKUP_OUTPUT_DIR=/var/lib/utility-watershed-analytics/backup/staging
BACKUP_STATE_DIR=/var/lib/utility-watershed-analytics/backup
BACKUP_MAX_AGE_SECONDS=90000
BACKUP_MAX_RTO_SECONDS=REPLACE_WITH_ACCEPTED_SECONDS
BACKUP_RESTIC_READ_DATA_SUBSET=5%

# Exact active release followed by two rollback releases. Retention fails closed
# when fewer than three unique snapshots are available.
BACKUP_RETAIN_RELEASE_IDS=REPLACE_ACTIVE,REPLACE_ROLLBACK_1,REPLACE_ROLLBACK_2

# Pin the production server image by digest for application restore smoke tests.
RESTORE_SERVER_IMAGE=utility-watershed-analytics-server@sha256:REPLACE_WITH_DIGEST
RESTORE_ALLOW_EMPTY_DATABASE=false
